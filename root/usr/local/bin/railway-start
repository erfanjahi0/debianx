#!/bin/sh
set -eu

# Railway provides PORT dynamically. LinuxServer/KasmVNC uses CUSTOM_PORT.
export CUSTOM_PORT="${PORT:-${CUSTOM_PORT:-8080}}"
export CUSTOM_HTTPS_PORT="${CUSTOM_HTTPS_PORT:-3001}"
export CUSTOM_USER="${CUSTOM_USER:-admin}"
export PASSWORD="${PASSWORD:-123456}"
export TITLE="${TITLE:-Railway KasmVNC Smooth Browser}"
export FM_HOME="${FM_HOME:-/config}"
export START_DOCKER="${START_DOCKER:-false}"
export PUID="${PUID:-1000}"
export PGID="${PGID:-1000}"
export SMOOTH_MODE="${SMOOTH_MODE:-true}"
export START_BROWSER="${START_BROWSER:-true}"
export WALLPAPER_FILE="${WALLPAPER_FILE:-/defaults/assets/wallpaper.png}"
export BROWSER_WINDOW_SIZE="${BROWSER_WINDOW_SIZE:-1000,560}"
export BROWSER_SCALE="${BROWSER_SCALE:-0.85}"
export BROWSER_RENDERERS="${BROWSER_RENDERERS:-2}"
export BROWSER_CACHE_MB="${BROWSER_CACHE_MB:-64}"
export BROWSER_HOME="${BROWSER_HOME:-https://www.google.com}"

# Smooth-mode desktop/browser environment.
export NO_AT_BRIDGE=1
export GDK_BACKEND="${GDK_BACKEND:-x11}"
export LIBGL_ALWAYS_SOFTWARE="${LIBGL_ALWAYS_SOFTWARE:-1}"
export CHROME_DEVEL_SANDBOX="${CHROME_DEVEL_SANDBOX:-/usr/lib/chromium/chrome-sandbox}"

# Clean stale locks from previous Railway restarts. This reduces browser/client crash loops.
rm -rf /tmp/.X*-lock /tmp/.X11-unix/X* /config/chromium-profile/Singleton* 2>/dev/null || true

# Prepare home before LinuxServer init drops to UID/GID 1000.
mkdir -p \
  /config/Desktop \
  /config/Downloads \
  /config/Documents \
  /config/chromium-profile \
  /config/.cache/chromium \
  /config/.config/openbox \
  /config/.config/pcmanfm/LXDE \
  /config/.local/share

# Own the main home so Chromium/downloads can write safely.
chown -R "${PUID}:${PGID}" /config 2>/dev/null || true
chmod -R u+rwX /config 2>/dev/null || true

# Optional GitHub-controlled wallpaper.
# Only this filename is supported: root/defaults/assets/wallpaper.png
# If it does not exist, the desktop keeps the lightweight default background.
if [ -f "$WALLPAPER_FILE" ]; then
  cp "$WALLPAPER_FILE" /config/.railway-wallpaper.png 2>/dev/null || true
  chown "${PUID}:${PGID}" /config/.railway-wallpaper.png 2>/dev/null || true
  chmod 0444 /config/.railway-wallpaper.png 2>/dev/null || true

  cat > /config/.config/pcmanfm/LXDE/desktop-items-0.conf <<'PCMANFM'
[*]
wallpaper_mode=stretch
wallpaper=/config/.railway-wallpaper.png
desktop_bg=#0e1117
desktop_fg=#e6eef6
desktop_shadow=#000000
show_wm_menu=1
sort=mtime;ascending;
show_documents=0
show_trash=0
show_mounts=0
PCMANFM
  echo "Custom wallpaper enabled: $WALLPAPER_FILE"
else
  rm -f /config/.railway-wallpaper.png 2>/dev/null || true
  cat > /config/.config/pcmanfm/LXDE/desktop-items-0.conf <<'PCMANFM'
[*]
wallpaper_mode=color
desktop_bg=#000000
desktop_fg=#e6eef6
desktop_shadow=#000000
show_wm_menu=1
sort=mtime;ascending;
show_documents=0
show_trash=0
show_mounts=0
PCMANFM
  echo "Custom wallpaper disabled: using default desktop background"
fi

# Keep wallpaper controlled from GitHub/redeploys, not from inside the desktop.
chown root:root /config/.config/pcmanfm/LXDE/desktop-items-0.conf 2>/dev/null || true
chmod 0444 /config/.config/pcmanfm/LXDE/desktop-items-0.conf 2>/dev/null || true

# Chromium managed policy: reduce background/telemetry/prompts.
mkdir -p /etc/chromium/policies/managed
cat > /etc/chromium/policies/managed/railway-low-resource.json <<'JSON'
{
  "BrowserSignin": 0,
  "SyncDisabled": true,
  "MetricsReportingEnabled": false,
  "DefaultNotificationsSetting": 2,
  "BackgroundModeEnabled": false,
  "AutofillAddressEnabled": false,
  "AutofillCreditCardEnabled": false,
  "PasswordManagerEnabled": false,
  "TranslateEnabled": false,
  "SafeBrowsingProtectionLevel": 1
}
JSON

cat <<INFO
============================================================
 Railway KasmVNC Smooth Cloud Browser - Heavy Browsing Build
============================================================
 Web port       : ${CUSTOM_PORT}
 Username       : ${CUSTOM_USER}
 Password       : ${PASSWORD}
 Home folder    : /config
 Desktop        : Openbox + tint2 + PCManFM desktop
 Browser        : Chromium high-survival mode
 File manager   : PCManFM
 Smooth mode    : ${SMOOTH_MODE}
 Start browser  : ${START_BROWSER}
 Browser scale  : ${BROWSER_SCALE}
 Renderers      : ${BROWSER_RENDERERS}
 Cache MB       : ${BROWSER_CACHE_MB}
 Wallpaper file : ${WALLPAPER_FILE} (optional PNG only)
============================================================
Generate Railway public URL using the Web port shown above.
For max smoothness: keep one KasmVNC tab and one to three browser tabs.
============================================================
INFO

exec /init

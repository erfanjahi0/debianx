#!/bin/sh

# Lightweight desktop session for Railway.
# Goal: browsing survival > visual quality. YouTube/Facebook still depend on Railway CPU/RAM.

export NO_AT_BRIDGE=1
export GDK_BACKEND=x11
export LIBGL_ALWAYS_SOFTWARE=1

# Start a tiny DBus session for GUI apps.
if command -v dbus-launch >/dev/null 2>&1; then
  eval "$(dbus-launch --sh-syntax)"
fi

mkdir -p \
  /config/Desktop \
  /config/Downloads \
  /config/Documents \
  /config/.config/openbox \
  /config/.config/pcmanfm/LXDE \
  /config/chromium-profile

# Openbox right-click menu. This is the real app menu.
cat > /config/.config/openbox/menu.xml <<'XML'
<?xml version="1.0" encoding="UTF-8"?>
<openbox_menu xmlns="http://openbox.org/3.4/menu">
  <menu id="root-menu" label="Applications">
    <item label="Chromium Browser">
      <action name="Execute"><command>cloud-browser</command></action>
    </item>
    <item label="File Manager">
      <action name="Execute"><command>pcmanfm /config</command></action>
    </item>
    <item label="Downloads">
      <action name="Execute"><command>pcmanfm /config/Downloads</command></action>
    </item>
    <item label="Terminal">
      <action name="Execute"><command>xterm</command></action>
    </item>
    <separator />
    <item label="Close Browser">
      <action name="Execute"><command>pkill chromium-browser; pkill chromium</command></action>
    </item>
    <item label="Reset Browser Cache">
      <action name="Execute"><command>xterm -e browser-reset</command></action>
    </item>
    <item label="Restart Desktop Panel">
      <action name="Execute"><command>pkill tint2; tint2</command></action>
    </item>
    <item label="Restart File Desktop">
      <action name="Execute"><command>pkill pcmanfm; pcmanfm --desktop --profile LXDE</command></action>
    </item>
    <item label="Reconfigure Openbox">
      <action name="Reconfigure" />
    </item>
  </menu>
</openbox_menu>
XML
openbox --reconfigure >/tmp/openbox-reconfigure.log 2>&1 || true

# Desktop shortcuts.
cat > /config/Desktop/Browser.desktop <<'DESK'
[Desktop Entry]
Type=Application
Name=Browser
Exec=cloud-browser
Icon=chromium
Terminal=false
DESK

cat > /config/Desktop/File-Manager.desktop <<'DESK'
[Desktop Entry]
Type=Application
Name=File Manager
Exec=pcmanfm /config
Icon=system-file-manager
Terminal=false
DESK

cat > /config/Desktop/Downloads.desktop <<'DESK'
[Desktop Entry]
Type=Application
Name=Downloads
Exec=pcmanfm /config/Downloads
Icon=folder-download
Terminal=false
DESK

cat > /config/Desktop/Terminal.desktop <<'DESK'
[Desktop Entry]
Type=Application
Name=Terminal
Exec=xterm
Icon=utilities-terminal
Terminal=false
DESK
chmod +x /config/Desktop/*.desktop 2>/dev/null || true

cat > /config/Desktop/README.txt <<'TXT' 2>/dev/null || true
Railway KasmVNC Smooth Browser

Use:
- Right-click empty desktop -> Applications -> Browser / File Manager
- Double-click Browser or File Manager icon
- Downloads are in /config/Downloads
- Optional wallpaper: add root/defaults/assets/wallpaper.png in GitHub and redeploy
- If browser keeps crashing: right-click desktop -> Applications -> Reset Browser Cache
TXT

# Desktop icons + forced wallpaper. If the config is read-only, ignore write errors.
pcmanfm --desktop --profile LXDE >/tmp/pcmanfm.log 2>&1 &

# Tiny panel.
tint2 >/tmp/tint2.log 2>&1 &

# Start exactly one browser window unless disabled.
if [ "${START_BROWSER:-true}" = "true" ]; then
  sleep 2
  if ! pgrep -f "chromium.*chromium-profile" >/dev/null 2>&1; then
    cloud-browser >/tmp/cloud-browser.log 2>&1 &
  fi
fi
